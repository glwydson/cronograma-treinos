# ============================================================
# Copie este arquivo para .env e preencha os valores reais
# NÃO commite o arquivo .env — ele está no .gitignore
# ============================================================

# Segredo JWT — use uma string longa e aleatória em produção
# Gere com: openssl rand -hex 64
JWT_SECRET=troque_por_um_segredo_forte_aqui

# Tempo de expiração do token (padrão: 7 dias)
JWT_EXPIRES_IN=7d

# URI do MongoDB (padrão para Docker Compose)
MONGODB_URI=mongodb://mongodb:27017/cronograma-treinos
